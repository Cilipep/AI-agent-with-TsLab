{
  "name": "TrendBot v1",
  "version": "1.0.0",
  "description": "Trend following strategy: EMA crossover + RSI correction + OBV confirmation",

  "timeframes": {
    "primary": "15m",
    "confirmation": "1h",
    "trend": "4h"
  },

  "strategy": {
    "ema_fast": 50,
    "ema_slow": 200,
    "rsi_period": 14,
    "rsi_correction_low": 40,
    "rsi_correction_high": 50,
    "obv_sma_period": 20,
    "min_volume_ratio": 1.2
  },

  "risk": {
    "sl_method": "ema200",
    "tp_method": "prev_high",
    "tp_lookback": 20,
    "risk_reward_min": 2.0,
    "max_risk_pct": 2.0
  },

  "sizing": {
    "usdt_per_pair": 10.0,
    "leverage": 20,
    "max_positions": 3
  },

  "filters": {
    "min_atr_pct": 0.3,
    "min_volume_usd": 5000000
  },

  "pairs": [
    "BTC", "ETH", "SOL", "BNB", "XRP", "ADA",
    "DOGE", "AVAX", "DOT", "LINK", "MATIC", "UNI",
    "ATOM", "LTC", "FIL", "NEAR", "APE", "AAVE"
  ]
}
